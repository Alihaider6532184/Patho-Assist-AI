# =============================================================================
# Patho-Assist AI — Root .gitignore
# =============================================================================

# ─── Python ───────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ─── Virtual Environments ─────────────────────────
venv/
.venv/
env/

# ─── Environment & Secrets (CRITICAL) ─────────────
.env
.env.*
!.env.example

# ─── ChromaDB (Local vector database — never commit)
backend/chroma_db/

# ─── Uploaded patient files (never commit) ────────
backend/uploads/

# ─── Node.js ──────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ──────────────────────────────────────
.next/
out/

# ─── Build artifacts ─────────────────────────────
build/
*.tsbuildinfo

# ─── IDE & Editor ────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ─── OS Generated ────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Debug logs ──────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Misc ────────────────────────────────────────
*.pem
.vercel
next-env.d.ts
