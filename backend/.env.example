# =============================================================================
# Patho-Assist AI — Environment Configuration (EXAMPLE)
# =============================================================================
# Copy this file to .env and adjust values if needed.
# All values stay local unless RUNTIME_MODE is set to "cloud".
# =============================================================================

# ─── Runtime Mode ─────────────────────────────────────────────────────────
# "local"  → All inference via Ollama (requires ollama serve + pulled models)
# "cloud"  → All inference via Llama API (requires LLAMA_API_KEY)
RUNTIME_MODE=local

# ─── Llama API (Cloud Mode) ──────────────────────────────────────────────
# Get your free API key at: https://llama.developer.meta.com/
LLAMA_API_KEY=your_llama_api_key_here
CLOUD_VISION_MODEL=Llama-4-Maverick-17B-128E-Instruct-FP8
CLOUD_TEXT_MODEL=Llama-3.3-70B-Instruct

# ─── Ollama (Local Mode) ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Model identifiers — must match `ollama list` output
VISION_MODEL=llava
TEXT_MODEL=gemma2:2b

# ChromaDB persistence directory (relative to backend/)
CHROMA_PERSIST_DIR=./chroma_db

# Embedding model for RAG (runs locally via sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Upload limits
MAX_PDF_SIZE_MB=50
MAX_IMAGE_SIZE_MB=20

# Chunk settings for PDF ingestion
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
