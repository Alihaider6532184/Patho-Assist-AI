# =============================================================================
# Patho-Assist AI — Environment Configuration (EXAMPLE)
# =============================================================================
# Copy this file to .env and adjust values if needed.
# All values stay local. Nothing is sent to external services.
# =============================================================================

# Ollama server URL (default local instance)
OLLAMA_BASE_URL=http://localhost:11434

# Model identifiers — must match `ollama list` output
VISION_MODEL=llava
TEXT_MODEL=gemma2:2b

# ChromaDB persistence directory (relative to backend/)
CHROMA_PERSIST_DIR=./chroma_db

# Embedding model for RAG (runs locally via sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Upload limits
MAX_PDF_SIZE_MB=50
MAX_IMAGE_SIZE_MB=20

# Chunk settings for PDF ingestion
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
